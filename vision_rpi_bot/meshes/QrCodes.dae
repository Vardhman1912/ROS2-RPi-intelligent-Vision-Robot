  <library_effects>
    <effect id="left_turn-effect">
      <profile_COMMON>
        <newparam sid="Image-surface">
          <surface type="2D">
            <init_from>Image</init_from>
          </surface>
        </newparam>
        <newparam sid="Image-sampler">
          <sampler2D>
            <source>Image-surface</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <lambert>
            <emission>
              <color sid="emission">0 0 0 1</color>
            </emission>
            <diffuse>
              <texture texture="Image-sampler" texcoord="UVMap"/>
            </diffuse>
            <index_of_refraction>
              <float sid="ior">1.45</float>
            </index_of_refraction>
          </lambert>
        </technique>
      </profile_COMMON>
    </effect>
    <effect id="right_turn-effect">
      <profile_COMMON>
        <newparam sid="right_png-surface">
          <surface type="2D">
            <init_from>right_png</init_from>
          </surface>
        </newparam>
        <newparam sid="right_png-sampler">
          <sampler2D>
            <source>right_png-surface</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <lambert>
            <emission>
              <color sid="emission">0 0 0 1</color>
            </emission>
            <diffuse>
              <texture texture="right_png-sampler" texcoord="UVMap"/>
            </diffuse>
            <index_of_refraction>
              <float sid="ior">1.45</float>
            </index_of_refraction>
          </lambert>
        </technique>
      </profile_COMMON>
    </effect>
    <effect id="stop-effect">
      <profile_COMMON>
        <newparam sid="stop_png-surface">
          <surface type="2D">
            <init_from>stop_png</init_from>
          </surface>
        </newparam>
        <newparam sid="stop_png-sampler">
          <sampler2D>
            <source>stop_png-surface</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <lambert>
            <emission>
              <color sid="emission">0 0 0 1</color>
            </emission>
            <diffuse>
              <texture texture="stop_png-sampler" texcoord="UVMap"/>
            </diffuse>
            <index_of_refraction>
              <float sid="ior">1.45</float>
            </index_of_refraction>
          </lambert>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>
  <library_images>
